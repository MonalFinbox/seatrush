# Copy to .env and adjust. Never commit the real .env.

# Postgres runs in Docker on host port 5433 (5432 is left to a local install).
DATABASE_URL=postgres://seatrush:seatrush@localhost:5433/seatrush?sslmode=disable
REDIS_ADDR=localhost:6379

# Secret used to sign JWTs. Use a long random value in production.
JWT_SECRET=change-me-to-a-long-random-secret

SERVER_PORT=8080

# Seeded admin account (created by `go run ./cmd/seed`). Admins can ONLY be
# seeded — there is no API path that creates one.
ADMIN_EMAIL=admin@seatrush.com
ADMIN_PASSWORD=change-me
# Extra static secret required on /auth/admin/login, on top of the password.
ADMIN_KEY=change-me-too

# Token lifetimes
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_HOURS=168

# Mock organizer registration fee (platform fee)
PLATFORM_FEE=4999.00

# How long a seat hold survives before the sweeper auto-releases it
HOLD_TTL_SECONDS=300
